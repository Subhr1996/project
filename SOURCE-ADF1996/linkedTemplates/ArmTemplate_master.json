{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "SOURCE-ADF1996"
		},
		"ADLS_SOURCE_LS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_SOURCE_LS'"
		},
		"SQL_SOURCE_LS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SQL_SOURCE_LS'"
		},
		"ADLS_SOURCE_LS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sourcelanding1996.dfs.core.windows.net/"
		},
		"SQL_SOURCE_LS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sourceserver2026.database.windows.net"
		},
		"SQL_SOURCE_LS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "SOURCE_DB"
		},
		"SQL_SOURCE_LS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sourceuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "SOURCE-ADF1996_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_SOURCE_LS_accountKey": {
						"value": "[parameters('ADLS_SOURCE_LS_accountKey')]"
					},
					"SQL_SOURCE_LS_password": {
						"value": "[parameters('SQL_SOURCE_LS_password')]"
					},
					"ADLS_SOURCE_LS_properties_typeProperties_url": {
						"value": "[parameters('ADLS_SOURCE_LS_properties_typeProperties_url')]"
					},
					"SQL_SOURCE_LS_properties_typeProperties_server": {
						"value": "[parameters('SQL_SOURCE_LS_properties_typeProperties_server')]"
					},
					"SQL_SOURCE_LS_properties_typeProperties_database": {
						"value": "[parameters('SQL_SOURCE_LS_properties_typeProperties_database')]"
					},
					"SQL_SOURCE_LS_properties_typeProperties_userName": {
						"value": "[parameters('SQL_SOURCE_LS_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}